# Site Configuration
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Cloudflare Turnstile (Anti-bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Vercel Blob Storage (for leads and gallery)
BLOB_READ_WRITE_TOKEN=your_blob_token

# Gallery Admin Authentication
GALLERY_ADMIN_PASSWORD=your_secure_admin_password
GALLERY_ADMIN_SESSION_SECRET=your_session_secret_min_32_chars

# Webhooks (Optional)
LEAD_WEBHOOK_URL=https://your-crm-webhook.com/endpoint
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
TELEMETRY_WEBHOOK_URL=https://your-analytics-webhook.com/endpoint

# Development
NODE_ENV=development